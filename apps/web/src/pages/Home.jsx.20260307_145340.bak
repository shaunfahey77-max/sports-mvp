import { useEffect, useState } from "react";
import { Link } from "react-router-dom";

export default function Home() {
  const [picks, setPicks] = useState([]);
  const [perf, setPerf] = useState(null);
  const [loading, setLoading] = useState(true);

  async function loadData() {
    try {
      const [predRes, perfRes] = await Promise.all([
        fetch("/api/predictions?league=nba"),
        fetch("/api/performance")
      ]);

      const predJson = await predRes.json();
      const perfJson = await perfRes.json();

      const bets = (predJson.games || [])
        .map(g => ({
          game: \`\${g.away?.abbr} @ ${g.home?.abbr}\`,
          bet: g.recommendedBet
        }))
        .filter(x => x.bet);

      setPicks(bets);
      setPerf(perfJson);
    } catch (err) {
      console.error(err);
    }

    setLoading(false);
  }

  useEffect(() => {
    loadData();
  }, []);

  if (loading) {
    return (
      <div className="p-6 text-white">
        Loading Sports MVP Dashboard...
      </div>
    );
  }

  return (
    <div className="p-6 text-white max-w-6xl mx-auto">

      <h1 className="text-3xl font-bold mb-6">
        Sports MVP Dashboard
      </h1>

      {/* Top Picks */}
      <div className="bg-slate-800 rounded-lg p-5 mb-6">
        <h2 className="text-xl font-semibold mb-4">Top Picks Today</h2>

        {picks.length === 0 && (
          <div className="text-slate-400">
            No premium picks available.
          </div>
        )}

        {picks.map((p, i) => (
          <div
            key={i}
            className="flex justify-between border-b border-slate-700 py-2"
          >
            <div>{p.game}</div>

            <div className="text-right">
              <div className="font-semibold">
                {p.bet.marketType} {p.bet.side}
              </div>

              <div className="text-sm text-slate-400">
                Tier: {p.bet.tier} • EV {Math.round(p.bet.evForStake100 || 0)}
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Performance */}
      <div className="bg-slate-800 rounded-lg p-5 mb-6">
        <h2 className="text-xl font-semibold mb-4">
          Model Performance (Last 7 Days)
        </h2>

        {perf && perf.rows?.nba && (
          <div className="grid grid-cols-3 gap-4">

            <div className="bg-slate-900 p-4 rounded">
              <div className="text-slate-400 text-sm">
                Total Picks
              </div>
              <div className="text-xl font-bold">
                {perf.rows.nba.reduce((a,b)=>a+b.picks,0)}
              </div>
            </div>

            <div className="bg-slate-900 p-4 rounded">
              <div className="text-slate-400 text-sm">
                Wins
              </div>
              <div className="text-xl font-bold">
                {perf.rows.nba.reduce((a,b)=>a+b.wins,0)}
              </div>
            </div>

            <div className="bg-slate-900 p-4 rounded">
              <div className="text-slate-400 text-sm">
                Losses
              </div>
              <div className="text-xl font-bold">
                {perf.rows.nba.reduce((a,b)=>a+b.losses,0)}
              </div>
            </div>

          </div>
        )}
      </div>

      {/* Quick Links */}
      <div className="bg-slate-800 rounded-lg p-5">

        <h2 className="text-xl font-semibold mb-4">
          Explore Predictions
        </h2>

        <div className="flex gap-4 flex-wrap">

          <Link
            className="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded"
            to="/predict-nba"
          >
            NBA Predictions
          </Link>

          <Link
            className="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded"
            to="/predict-nhl"
          >
            NHL Predictions
          </Link>

          <Link
            className="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded"
            to="/ncaab-predictions"
          >
            NCAAB Predictions
          </Link>

          <Link
            className="bg-slate-600 hover:bg-slate-700 px-4 py-2 rounded"
            to="/performance"
          >
            Model Performance
          </Link>

        </div>
      </div>

    </div>
  );
}

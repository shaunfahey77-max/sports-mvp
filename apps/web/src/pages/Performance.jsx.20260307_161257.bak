import { useEffect, useState } from "react";

export default function Performance() {
  const [days, setDays] = useState(90);
  const [data, setData] = useState(null);

  async function load() {
    const res = await fetch(`/api/performance?days=${days}&leagues=nba,ncaam,nhl`);
    const json = await res.json();
    setData(json);
  }

  useEffect(() => {
    load();
  }, [days]);

  const rows = data?.rows || {};
  const markets = data?.byMarket || {};

  return (
    <div style={{ padding: 30 }}>

      <h1>Performance</h1>

      <div style={{ marginBottom: 20 }}>
        {[7, 30, 90].map(d => (
          <button
            key={d}
            style={{
              marginRight: 10,
              padding: "6px 12px",
              borderRadius: 6,
              background: days === d ? "#2a72ff" : "#222",
              color: "#fff",
              border: "none",
              cursor: "pointer"
            }}
            onClick={() => setDays(d)}
          >
            {d} Days
          </button>
        ))}
      </div>

      <div>
        <h2>Performance by Market</h2>

        <table style={{ width: "100%" }}>
          <thead>
            <tr>
              <th>Market</th>
              <th>Wins</th>
              <th>Losses</th>
              <th>Win Rate</th>
            </tr>
          </thead>

          <tbody>
            {Object.entries(markets).map(([k,v]) => (
              <tr key={k}>
                <td>{k}</td>
                <td>{v.wins}</td>
                <td>{v.losses}</td>
                <td>{v.winRate ? (v.winRate*100).toFixed(1)+"%" : "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div style={{ marginTop: 30 }}>
        <h2>Daily Results</h2>

        {Object.entries(rows).map(([league,data]) => (
          <div key={league} style={{ marginTop: 20 }}>
            <h3>{league.toUpperCase()}</h3>

            <table style={{ width: "100%" }}>
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Picks</th>
                  <th>Wins</th>
                  <th>Losses</th>
                  <th>Win Rate</th>
                </tr>
              </thead>

              <tbody>
                {data.map(r => (
                  <tr key={r.date}>
                    <td>{r.date}</td>
                    <td>{r.picks}</td>
                    <td>{r.wins}</td>
                    <td>{r.losses}</td>
                    <td>{r.acc ? (r.acc*100).toFixed(1)+"%" : "—"}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ))}

      </div>

    </div>
  );
}

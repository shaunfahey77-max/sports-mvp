modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = "pnpm --filter @workspace/api-server run start"
build = "pnpm --filter @workspace/api-server run build"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["lsof", "psmisc"]

[userenv]

[userenv.shared]
CLERK_PUBLISHABLE_KEY = "pk_live_Y2xlcmsuc3BvcnRzbXZwLm5ldCQ"

[userenv.production]
VITE_CLERK_KEY = "pk_live_Y2xlcmsuc3BvcnRzbXZwLm5ldCQ"
DISABLE_CRON = "true"

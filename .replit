modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = "pnpm --filter @workspace/api-server run start"
build = "pnpm --filter @workspace/api-server run build"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-typecheck-baseline"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-tests"

[[workflows.workflow]]
name = "api-typecheck-baseline"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'errs=$(pnpm --filter @workspace/api-server exec tsc --noEmit 2>&1 | grep -cE \"error TS\" || true); echo \"typecheck errors: $errs (baseline on main: 26; task asserts <=23)\"; test \"$errs\" -le 23'"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-tests"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "LOG_LEVEL=silent pnpm --filter @workspace/api-server exec tsx --test src/scoring/__tests__/computeOutcomeResult.test.ts src/scoring/__tests__/ncaafTeamAbbreviations.test.ts src/scoring/__tests__/nflSpreadModel.test.ts src/scoring/__tests__/ncaafSpreadModel.test.ts src/scoring/__tests__/clvWriteback.test.ts src/scoring/__tests__/modelWatchAggregator.test.ts src/scoring/__tests__/marketModelWatchOnly.test.ts src/scoring/__tests__/brierScore.test.ts src/scoring/__tests__/monotonicity.test.ts src/scoring/__tests__/cohortAnalysis.test.ts src/lib/__tests__/pickBestLines.test.ts src/lib/__tests__/transformGame.test.ts"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["lsof", "psmisc"]

[userenv]

[userenv.shared]
CLERK_PUBLISHABLE_KEY = "pk_live_Y2xlcmsuc3BvcnRzbXZwLm5ldCQ"

[userenv.production]
VITE_CLERK_KEY = "pk_live_Y2xlcmsuc3BvcnRzbXZwLm5ldCQ"
